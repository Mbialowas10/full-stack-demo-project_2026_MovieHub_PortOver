generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TMDBMovie {
  id           Int      @id @default(autoincrement())
  tmdb_id      Int      @unique
  title        String
  overview     String?
  release_date DateTime?
  poster_path  String?
  popularity   Float?
  vote_average Float?
  vote_count   Int?
  createdAt    DateTime @default(now())
  reviews    Review[]
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  reviews    Review[]
  createdAt DateTime   @default(now())
}

model Review {
  id      Int   @id @default(autoincrement())
  user    User  @relation(fields: [userId], references: [id])
  userId  Int
  movie   TMDBMovie @relation(fields: [movieId], references: [id])
  movieId Int
  rating  Int
  comment String
  createdAt DateTime @default(now())
}

