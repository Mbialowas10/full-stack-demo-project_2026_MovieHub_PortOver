{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "sourceMap": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "*": ["*"],
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/**/*", "api/index.ts", "src/types/**/*"],
  "exclude": ["node_modules", "dist"]
}